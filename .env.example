# LeetCode Solution Post Generator Configuration

# ------------------------------------------------------------------------------
# LLM PROVIDER SELECTION
# Options: 'gemini' or 'local' (Ollama)
# ------------------------------------------------------------------------------
LLM_PROVIDER=gemini

# ------------------------------------------------------------------------------
# GEMINI API CONFIGURATION
# Required if LLM_PROVIDER=gemini. Get your free API key from Google AI Studio.
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# LOCAL OLLAMA CONFIGURATION
# Required if LLM_PROVIDER=local. Make sure Ollama is running.
# ------------------------------------------------------------------------------
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=llama3

# ------------------------------------------------------------------------------
# LEETCODE CREDENTIALS (CRITICAL FOR MY CODE EXTRACTION)
# Paste your session details here. To get these:
# 1. Open leetcode.com in your browser and make sure you are logged in.
# 2. Open Developer Tools (F12) -> Application (Chrome) or Storage (Firefox) -> Cookies.
# 3. Copy the values of 'LEETCODE_SESSION' and 'csrftoken'.
# ------------------------------------------------------------------------------
LEETCODE_SESSION=your_leetcode_session_cookie_here
CSRF_TOKEN=your_leetcode_csrftoken_here
